{
  "name": "tempo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multiplayer cyberpunk combat racer for the web.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "check:track": "tsx scripts/analyze-track-topology.ts --song the-prodigy-firestarter --samples 2200 --threshold 12.5 --assert-min-tangent-dot -0.75",
    "start": "node --enable-source-maps dist-server/src/server/index.js",
    "server": "node --enable-source-maps dist-server/src/server/index.js",
    "build:server": "tsc -p tsconfig.server.json",
    "dev:server": "tsx watch src/server/index.ts",
    "upload:assets": "node --env-file=.env scripts/upload-assets.mjs"
  },
  "dependencies": {
    "three": "^0.176.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@types/node": "^22.14.1",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.18"
  }
}
