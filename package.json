{
  "name": "tempo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multiplayer cyberpunk combat racer for the web.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server": "node --enable-source-maps dist-server/server/index.js",
    "build:server": "tsc -p tsconfig.server.json",
    "dev:server": "tsx watch src/server/index.ts"
  },
  "dependencies": {
    "three": "^0.176.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.18"
  }
}
